{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**"],
      "dependsOn": ["^build"]
    },
    "build:metadata": {
      "outputs": ["dist/**"],
      "dependsOn": ["build"]
    },
    "build-all": {
      "dependsOn": ["build", "build:metadata"]
    },
    "clean": {
      "cache": false,
      "dependsOn": ["clean:lib", "clean:output"]
    },
    "clean:lib": {
      "cache": false,
      "dependsOn": ["^clean:lib"]
    },
    "clean:output": {
      "cache": false,
      "dependsOn": ["^clean:output"]
    }
  }
}
