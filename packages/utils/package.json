{
  "name": "@pawover/kit-utils",
  "author": {
    "name": "pawover",
    "email": "pawover@outlook.com",
    "url": "https://github.com/pawover"
  },
  "description": "pawover's kit-utils",
  "version": "0.0.0-alpha.1",
  "type": "module",
  "keywords": [
    "pawover",
    "pawover-kit-utils"
  ],
  "homepage": "https://github.com/pawover/pawover-kit/packages/utils#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pawover/pawover-kit.git"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./math": {
      "development": "./src/math/index.ts",
      "types": "./dist/math.d.ts",
      "import": "./dist/math.js",
      "default": "./dist/math.js"
    },
    "./vite": {
      "development": "./src/vite/index.ts",
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "default": "./dist/vite.js"
    },
    "./metadata.json": "./dist/metadata.json"
  },
  "scripts": {
    "build:source": "tsdown",
    "build:metadata": "node scripts/metadata.ts",
    "package": "pnpm pack",
    "public": "npm publish --access public --tag alpha",
    "check:pack": "attw --pack ."
  },
  "devDependencies": {
    "@pawover/types": "0.0.2",
    "ts-toolbelt": "^9.6.0",
    "type-fest": "^5.8.0"
  },
  "peerDependencies": {
    "mathjs": "^15.2.0",
    "vite": "^7 || ^8"
  },
  "peerDependenciesMeta": {
    "mathjs": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}
