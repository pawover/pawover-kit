{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "erasableSyntaxOnly": false,
    "allowUnusedLabels": true,
    "noUnusedLocals": false
  },
  "include": ["**/*.js", "**/*.cjs", "**/*.mjs", "**/*.ts", "**/*.jsx", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/dist"]
}
